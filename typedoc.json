{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/assert/index.ts",
    "src/runner/index.ts",
    "src/refiner/main.ts",
    "src/testing/index.ts",
    "src/testing/plugins.ts",
    "src/reporters/index.ts",
    "src/commands/index.ts"
  ],
  "out": "docs",
  "name": "Lupa",
  "includeVersion": true,
  "readme": "README.md",
  "disableSources": false,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "projectDocuments": ["guides/**/*.md"],
  "customCss": "assets/docs.css",
  "lightHighlightTheme": "dark-plus",
  "plugin": ["@to-skills/typedoc"],
  "externalSymbolLinkMappings": {
    "typescript": {
      "AbortSignal": "https://developer.mozilla.org/en-US/docs/Web/API/AbortSignal",
      "Disposable": "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Symbol/dispose"
    }
  }
}
